<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="graphical.controllers.LoginController"
           fx:id="rootPane">
    <children>
        <Pane styleClass="background-gradient"/>
        <VBox spacing="20" alignment="CENTER" maxWidth="400" maxHeight="350"
              styleClass="login-card">
            <Label text="Welcome Back" styleClass="title"/>
            <VBox spacing="10" maxWidth="300">
                <TextField fx:id="usernameField" promptText="Enter your username" styleClass="text-field-modern"/>
                <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="text-field-modern"/>
            </VBox>
            <Button fx:id="loginButton" text="Login" onAction="#onLogin" styleClass="login-button"/>
            <HBox alignment="CENTER" spacing="6">
                <Label text="Not a member yet?" styleClass="normal-text"/>
                <Hyperlink fx:id="registerNowLink" text="Create an account now" onAction="#onCreateAccount" styleClass="now-link"/>
            </HBox>
        </VBox>
    </children>
</StackPane>
