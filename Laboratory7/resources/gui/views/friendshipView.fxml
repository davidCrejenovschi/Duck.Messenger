<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.graphical.controllers.FriendshipController">

    <VBox spacing="20" alignment="CENTER"
          AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0">

        <HBox spacing="10" alignment="CENTER">
            <Label text="User 1 ID:"/>
            <TextField fx:id="user1Field" promptText="Enter first user ID" prefWidth="150"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER">
            <Label text="User 2 ID:"/>
            <TextField fx:id="user2Field" promptText="Enter second user ID" prefWidth="150"/>
        </HBox>

        <HBox spacing="20" alignment="CENTER">
            <Button fx:id="addButton" text="Add Friendship" onAction="#onAddFriendship"/>
            <Button fx:id="removeButton" text="Remove Friendship" onAction="#onRemoveFriendship"/>
        </HBox>

        <HBox alignment="CENTER">
            <TableView fx:id="friendshipTable" prefWidth="500" prefHeight="350">
                <columns>
                    <TableColumn fx:id="colUser1" text="User 1"/>
                    <TableColumn fx:id="colUser2" text="User 2"/>
                </columns>
            </TableView>
        </HBox>

        <HBox spacing="20" alignment="CENTER">
            <Button fx:id="mostSociableCommunityButton" text="Most Sociable Community" onAction="#onMostSociableCommunityButton"/>
            <Button fx:id="communitiesButton" text="Number of Communities" onAction="#onCommunitiesButton"/>
        </HBox>

        <HBox alignment="CENTER">
            <TextArea fx:id="smallScreen" prefWidth="300" prefHeight="100" editable="false"
                      promptText="Output screen..."/>
        </HBox>

    </VBox>

    <Button fx:id="backButton" onAction="#onBack" styleClass="back-button"
            prefWidth="40" prefHeight="40"
            AnchorPane.leftAnchor="10"
            AnchorPane.topAnchor="10"/>

</AnchorPane>
